# ============================================================
# .gitignore - 防止敏感信息提交到Git仓库
# ============================================================

# 虚拟环境
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# 敏感配置
.env

# 数据库
data/*.db

# 上传文件（临时）
uploads/*

# IDE配置
.vscode/
.idea/

# 系统文件
Thumbs.db
.DS_Store
*.log
